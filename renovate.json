{
  "extends": ["config:base"],
  "baseBranches": ["main"],

  "automerge": true,
  "automergeType": "pr",
  "platformAutomerge": true,
  "rebaseWhen": "auto",

  "packageRules": [
    {
      "matchDatasources": ["docker"],
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true,
      "autoApprove": true
    }
  ],

  "autoApprove": true,
  "dependencyDashboard": false,

  "hostRules": [
    {
      "matchHost": "docker.io",
      "hostType": "docker",
      "username": "{{ secrets.DOCKERHUB_USERNAME }}",
      "password": "{{ secrets.DOCKERHUB_TOKEN }}"
    }
  ]
}